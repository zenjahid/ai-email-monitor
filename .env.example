# =============================================================================
# AI Email Reading Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Email Source -----------------------------------------------------------
# Options: mock | imap
EMAIL_SOURCE=mock

# IMAP Settings (used when EMAIL_SOURCE=imap)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# --- AI Provider ------------------------------------------------------------
# Options: openai | openai_compat | local | rule_based
PROVIDER=openai

# OpenAI (used when PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OpenAI-Compatible (used when PROVIDER=openai_compat)
# Examples: OpenRouter, Groq, Together AI, etc.
OPENAI_COMPAT_BASE_URL=https://openrouter.ai/api/v1
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=anthropic/claude-3-haiku

# Ollama Local LLM (used when PROVIDER=local)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# --- General -----------------------------------------------------------------
POLL_INTERVAL=120
DATABASE_PATH=data/emails.db
DEBUG=false
